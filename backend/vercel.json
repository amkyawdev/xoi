{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "buildCommand": "pip install -r requirements.txt",
  "outputDirectory": ".vercel/output",
  "installCommand": "pip install -r requirements.txt",
  "framework": null,
  "env": [
    {
      "key": "PYTHON_VERSION",
      "value": "3.11"
    }
  ]
}
