# Application Settings
APP_NAME=web-agent-platform
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# API Keys
OPENAI_API_KEY=your-openai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/webagent
REDIS_URL=redis://localhost:6379/0
CHROMA_DB_PATH=./storage/vectors

# Security
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
MAX_REQUEST_SIZE=10485760

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# Crawler Settings
MAX_CRAWL_DEPTH=5
CRAWL_TIMEOUT_SECONDS=30
MAX_CONCURRENT_CRAWLS=10

# LLM Settings
DEFAULT_MODEL=gpt-4
FALLBACK_MODEL=gpt-3.5-turbo
TEMPERATURE=0.7
MAX_TOKENS=4096

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=false
