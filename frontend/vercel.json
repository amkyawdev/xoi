{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "pages/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "src/**",
      "use": "@vercel/static"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/about",
      "dest": "/pages/about.html"
    },
    {
      "src": "/docs",
      "dest": "/pages/docs.html"
    },
    {
      "src": "/skills",
      "dest": "/pages/skills.html"
    },
    {
      "src": "/chat",
      "dest": "/pages/chat.html"
    },
    {
      "src": "/login",
      "dest": "/pages/login.html"
    },
    {
      "src": "/register",
      "dest": "/pages/register.html"
    },
    {
      "src": "/reset",
      "dest": "/pages/reset.html"
    },
    {
      "src": "/(.*)",
      "dest": "/pages/$1"
    }
  ]
}
